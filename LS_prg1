def linear_search(arr, target):
      for i in range(len(arr)):
          if arr[i] == target:
              return i
      return -1
  
arr = ["milk","sugar","rice","oil"]
target = "milk"
result = linear_search(arr, target)
  
if result != -1:
      print("Product found at index")
else:
      print("product not found")
  
